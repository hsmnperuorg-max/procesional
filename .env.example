# Copiar este archivo a ".env" y completar con los valores reales.
# Nunca commitear el ".env" real (ya está en .gitignore).

SECRET_KEY=cambia-esto-por-una-clave-secreta-larga-y-unica
DEBUG=False

# Dominios permitidos, separados por coma (sin protocolo).
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Cadena de conexión a Postgres. En Neon/Render viene con sslmode=require incluido.
# Para Postgres local (docker-compose o instalación propia) usar algo como:
#   postgres://usuario:password@localhost:5432/procesional
DATABASE_URL=postgres://usuario:password@localhost:5432/procesional

# "require" en producción (Neon lo exige); "disable" para Postgres local sin SSL.
DB_SSLMODE=require

# Solo para docker-compose (VPS con Postgres en contenedor):
DB_NAME=procesional
DB_USER=procesional
DB_PASSWORD=cambia-esta-clave
